<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Login</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/login.css">
    <link rel="stylesheet" href="/CSS/dashboard.css">
</head>
<body>

    <a href="/" style="text-decoration: none; color: white;">
        <div class="btn-secondary-dash back-button">
            <i class="fas fa-undo-alt"></i> VOLTAR
        </div>
    </a>

    <div class="page">
        <div class="logo-analisai">
            <img src="/IMG/logo3-white.png" alt="AnalisAI">
        </div>

        <div class="login-container">
            
            <% if (error_msg && error_msg.length > 0) { %>
                <div class="erro-box">
                    <%= error_msg %>
                </div>
            <% } %>
            
            <% if (success_msg && success_msg.length > 0) { %>
                <div class="success-box">
                    <%= success_msg %>
                </div>
            <% } %>

            <form action="/login" method="POST">
                <div class="input-group">
                    <input type="text" name="usuario" placeholder="USUÁRIO" required>
                </div>
                
                <div class="input-group">
                    <input type="password" name="senha" placeholder="SENHA" required>
                </div>
                
                <button type="submit">ENTRAR</button>
            </form>
        </div>

        <div class="signup-link">
            <a href="/cadastro">NÃO TEM UMA CONTA? CADASTRE-SE!</a>
        </div>

        <footer class="footer-terms">
            <i class="fas fa-shield-alt"></i>
            <a href="/termos" class="termos">
                <span>TERMOS DE SERVIÇO</span>
            </a>
        </footer>
    </div>

</body>
</html>