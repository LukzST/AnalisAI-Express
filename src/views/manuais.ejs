<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Manual do Usuário</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/sidebar.css">
    <link rel="stylesheet" href="/CSS/dashboard.css">
    <style>

        .cards {
            display: flex;
            flex-direction: column;
            gap: 20px;
            justify-content: center;
            align-items: center;
        }

        .card {
            width: 100%;
            max-width: 600px;
            background-color: #ffffff00;
            border-radius: 12px;
            border: 1px solid #1a1a1a;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }


        .title {
            font-size: 1.7rem;
            margin-bottom: 10px;
        }

        .button {
            display: inline-block;
            padding: 10px 20px;
            background-color: #ff0101;
            max-width: 100px;
            color: #ffffff;
            text-decoration: none;
            border-radius: 800px;
            transition: background-color 0.3s ease;
        }

        .button:hover {
            background-color: #080808;
            border: 1px solid #ff0101;
        }

    </style>
</head>
<body class="dash-body">
    <%- include('Partials/sidebar') %>
    
    <div class="main-layout">
        <header class="dash-header">
            <div class="logo">
                <img src="/IMG/logo3-white.png" alt="AnalisAI">
            </div>
            <h2 class="page-title">MANUAL DO USUÁRIO</h2>
        </header>

        <main class="cards">
            <div class="card">
                <h1 class="title">
                    Manual do Professor
                </h1>
                <a href="/manuais/manual-de-uso" id="professorBtn" class="button">
                    Acessar
                </a>
            </div>
            <div class="card">
                <h1 class="title">
                    Manual do Aluno
                </h1>
                <a href="/manuais/manual-do-aluno" id="alunoBtn" class="button">
                    Acessar
                </a>
            </div>
        </main>

    </div>
</body>
</html>