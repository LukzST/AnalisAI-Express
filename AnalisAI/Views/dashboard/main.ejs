<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/sidebar.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body class="dash-body">

    <%- include('../partials/sidebar') %>

    <div class="main-layout">
        <header class="dash-header">
            <div class="logo">
                <img src="/img/logo3-white.png" alt="AnalisAI">
            </div>
            <div class="header-user">
                <span>Bem-vindo, <strong><%= user %></strong></span>
                <a href="/logout" class="logout-icon" title="Sair">
                    <i class="fas fa-sign-out-alt"></i>
                </a>
            </div>
        </header>

        <main class="dash-content">
            <section class="section-container">
                <h2 class="section-title"><i class="fas fa-graduation-cap"></i> ENSINO MÉDIO</h2>
                <div class="dash-grid">
                    <div class="stats-card">
                        <div class="stats-info">
                            <h3>TOTAL ALUNOS</h3>
                            <p class="stats-number"><%= alunos.filter(a => a.ano_escolar.includes('MÉDIO')).length %></p>
                        </div>
                        <i class="fas fa-users icon-bg"></i>
                    </div>
                    
                    <div class="stats-card apto">
                        <div class="stats-info">
                            <h3>APTOS</h3>
                            <p class="stats-number"><%= alunos.filter(a => a.ano_escolar.includes('MÉDIO') && a.nota >= 7 && a.presenca >= 75).length %></p>
                        </div>
                        <i class="fas fa-check-circle icon-bg"></i>
                    </div>

                    <div class="stats-card inapto">
                        <div class="stats-info">
                            <h3>INAPTOS</h3>
                            <p class="stats-number"><%= alunos.filter(a => a.ano_escolar.includes('MÉDIO') && (a.nota < 5 || a.presenca < 50)).length %></p>
                        </div>
                        <i class="fas fa-times-circle icon-bg"></i>
                    </div>
                </div>
            </section>

            <section class="section-container">
                <h2 class="section-title"><i class="fas fa-book"></i> ENSINO FUNDAMENTAL</h2>
                <div class="dash-grid">
                    <div class="stats-card">
                        <div class="stats-info">
                            <h3>TOTAL ALUNOS</h3>
                            <p class="stats-number"><%= alunos.filter(a => a.ano_escolar.includes('FUNDAMENTAL')).length %></p>
                        </div>
                        <i class="fas fa-users icon-bg"></i>
                    </div>

                    <div class="stats-card apto">
                        <div class="stats-info">
                            <h3>APTOS</h3>
                            <p class="stats-number"><%= alunos.filter(a => a.ano_escolar.includes('FUNDAMENTAL') && a.nota >= 7 && a.presenca >= 75).length %></p>
                        </div>
                        <i class="fas fa-check-circle icon-bg"></i>
                    </div>

                    <div class="stats-card inapto">
                        <div class="stats-info">
                            <h3>INAPTOS</h3>
                            <p class="stats-number"><%= alunos.filter(a => a.ano_escolar.includes('FUNDAMENTAL') && (a.nota < 5 || a.presenca < 50)).length %></p>
                        </div>
                        <i class="fas fa-times-circle icon-bg"></i>
                    </div>
                </div>
            </section>
        </main>

        <footer class="dash-footer">
            <div class="footer-actions">
                <a href="/dashboard/edit" class="btn-secondary-dash">
                    <i class="fas fa-pencil-alt"></i> GERENCIAR NOTAS
                </a>
                <a href="/dashboard/graficos" class="btn-secondary-dash">
                    <i class="fas fa-chart-pie"></i> VER ESTATÍSTICAS
                </a>
            </div>
            <div class="footer-credits">
                <p>© 2026 AnalisAI — SENAI Duque de Caxias.</p>
                <a href="/dashboard/equipe"><p>Time de desenvolvedores</p></a>
            </div>
        </footer>
    </div>
</body>
</html>